{
  "layer": "top",
  "height": 35,
  "modules-left": ["cpu", "memory", "temperature", "hyprland/workspaces"],
  "modules-center": ["hyprland/window"],
  "modules-right": ["tray", "custom/updates", "backlight", "pulseaudio", "battery", "network", "clock"],

  "custom/updates": {
    "format": "яГн {}",
    "exec": "dnf check-update | grep -Ec ' updates' | tr -d '\n'",
    "restart-interval": 60,
  },

  "hyprland/window": {
    "format": "{title}"
  },

  "backlight": {
    "format": "{icon}  {percent}%",
    "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
  },

  "tray": {
    "icon-size": 21,
    "spacing": 10,
  },

  "wlr/taskbar": {
    "on-click": "activate",
    "icon-size": 21,
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "яЪй  {volume}%",
    "format-icons": {
      "default": ["яАж", "яАз", "яАи"],
    }
  },

  "cpu": {
    "format": "яЛЫ  {usage}%",
  },

  "temperature": {
    "format": "{icon}  {temperatureC}┬░C",
    "format-icons": ["яЭл", "яЛЙ", "яЭй"]
  },

  "memory": {
    "format": "яФ╕  {}%",
  },

  "network": {
    "format-wifi": "яЗл  {essid}",
    "format-ethernet": "{ipaddr}/{cidr} яЮЦ",
    "tooltip-format": "Connected to {essid}",
    "format-linked": "{ifname} (No IP) яЮЦ",
    "format-disconnected": "тЪа Disconnected",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },

  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "яЧз  {capacity}%",
    "format-plugged": "яЗж  {capacity}%",
    "format-alt": "{time} {icon}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },

  "clock": {
    "format": "яАЧ  {:%H:%M}",
    "timezone": "Europe/Berlin",
  },
}
